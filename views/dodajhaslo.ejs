<!DOCTYPE html>
<html data-theme="<%- app.theme %>" lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css" />
  <title><%= title %></title>
</head>
<body>
  <main>
    <h1><%= title %></h1>

<table class="tabela">
<tr>

<td>
<h2>Dodaj hasło</h2>

<form action="/formularz/haslo/dodaj" method="POST">
  <label>Wybierz kategorię:</label><br>
  <select name="categoryId" required>
    <% kategorie.forEach(cat => { %>
      <option value="<%= cat.id %>"><%= cat.name %></option>
    <% }) %>
  </select><br>

  <label>Hasło:</label><br>
  <input type="text" name="text" required><br>
  <button type="submit">Dodaj hasło</button>
</form>
</td>

<td>
<h2>Edycja hasła</h2>

<% kategorie.forEach(cat => { %>
  <details>
    <summary><%= cat.name %></summary>

    <% cat.words.forEach(word => { %>
      <div class="word-item">
        <form style="display:inline;" method="POST" action="/formularz/haslo/edytuj">
          <input type="hidden" name="id" value="<%= word.id %>">
          <input type="hidden" name="categoryId" value="<%= cat.id %>">
          <input type="text" name="text" value="<%= word.text %>" required>
          <button type="submit">Edytuj</button>
        </form>

        <form style="display:inline;" method="POST" action="/formularz/haslo/usun">
          <input type="hidden" name="id" value="<%= word.id %>">
          <button type="submit">Usuń</button>
        </form>
      </div>
    <% }) %>

  </details>
<% }) %>

</td>

</tr>
</table>
    <br>
    <a href="/hasla">Powrót do listy kategorii</a><br>
    <a href="/">Powrót do strony głównej</a>
  </main>
</body>
</html>